# Copy this file to `.env` (or export the variable in your shell) to enable
# LLM-backed natural-language prompt parsing on POST /api/query/nlp and
# POST /api/query/execute. Without it, a deterministic rule-based parser is
# used automatically, so the app works fine without this key.

# NVIDIA NIM API key (https://build.nvidia.com/), used to call the
# chat completion endpoint.
NIM_API_KEY=

# Optional: comma-separated list of NIM model IDs to try, in order. If a
# model errors out or doesn't respond within ~8s, the next one in the list
# is tried immediately. If all of them fail, the app falls back to the
# deterministic rule-based parser. Defaults to:
# mistralai/ministral-14b-instruct-2512,openai/gpt-oss-120b,nvidia/nemotron-3-ultra-550b-a55b
NIM_MODELS=
