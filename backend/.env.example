# Copy this file to `.env` (or export the variable in your shell) to enable
# LLM-backed natural-language prompt parsing on POST /api/query/nlp and
# POST /api/query/execute. Without it, a deterministic rule-based parser is
# used automatically, so the app works fine without this key.

# NVIDIA NIM API key (https://build.nvidia.com/), used to call the
# openai/gpt-oss-120b chat completion endpoint.
NIM_API_KEY=
